{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/build/$1" },
    { "src": "/img/(.*)", "dest": "/img/$1" },
    { "src": "/storage/(.*)", "dest": "/storage/$1" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/(.*\\.(?:png|jpg|jpeg|gif|svg|webp|avif|ico|txt|js|css|map))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "buildCommand": "php -r \"copy('https://getcomposer.org/installer', 'composer-setup.php');\" && php composer-setup.php --install-dir=. --filename=composer.phar && php composer.phar install --no-dev --prefer-dist --optimize-autoloader --no-interaction && rm -f composer-setup.php composer.phar && npm install && npm run build && mkdir -p public/storage/img && cp -R public/img/* public/storage/img/",
  "outputDirectory": "public",
  "env": {
    "APP_URL": "https://dunkers-ecommerce.vercel.app",
    "ASSET_URL": "https://dunkers-ecommerce.vercel.app",
    "APP_ENV": "production",
    "APP_KEY": "base64:SkHG2mjK/CyXByGhy7zONEgXYjVRedIBaIpKKwvjp2w=",
    "APP_DEBUG": "false",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp",
    "CACHE_DRIVER": "array",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "QUEUE_CONNECTION": "sync"
  }
}
